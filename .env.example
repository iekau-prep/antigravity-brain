# Example Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your .env file to git!

# API Keys
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Database Config
# DB_HOST=localhost
# DB_USER=admin
# DB_PASS=secret

# App Settings
# DEBUG=true
